		{
			"name": "2. Tasks Management",
			"item": [
				{
					"name": "Get Tasks - Success (200)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/tasks?status=pending&search=Refactor&page=1&limit=6",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"tasks"
							],
							"query": [
								{
									"key": "status",
									"value": "pending"
								},
								{
									"key": "search",
									"value": "Refactor"
								},
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "6"
								}
							]
						},
						"description": "Retrieves the authenticated user's tasks. Supports search, status filtering, and limit query parameter. Returns HTTP 200 OK."
					},
					"response": []
				},
